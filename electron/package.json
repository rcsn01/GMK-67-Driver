{
  "name": "gmk67-electron",
  "version": "0.1.0",
  "description": "Electron UI for the GMK67 driver",
  "private": true,
  "main": ".vite/build/main.js",
  "scripts": {
    "ensure-helper": "node scripts/ensure-helper.mjs",
    "dev": "npm run ensure-helper && electron-forge start",
    "start": "npm run dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "npm run typecheck && vite build",
    "prepare-helper": "node scripts/prepare-helper.mjs",
    "package": "npm run prepare-helper && electron-forge package",
    "package:mac": "npm run prepare-helper && electron-forge package --platform=darwin"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@electron-forge/shared-types": "^7.6.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "electron": "^33.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
